generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String         @id @default(uuid())
  name        String
  description String?
  subject     String         @default("OTHER") // HINDI, MATHS, ENGLISH, SCIENCE, PHYSICS, CHEMISTRY, OTHER
  status      String         @default("DRAFT") // DRAFT, PROCESSING, COMPLETED, ERROR
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProjectImage[]
}

model ProjectImage {
  id           String   @id @default(uuid())
  projectId    String
  filename     String
  originalName String
  orderIndex   Int
  ocrText      String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
